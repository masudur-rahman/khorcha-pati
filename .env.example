# ══════════════════════════════════════════════════════════════════════════════
# Khorcha-Pati — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit a filled-in .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Telegram (required) ──────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Telegram username granted dashboard admin (overrides telegram.bot_owner in YAML)
# EXPENSE_BOT_OWNER=your_telegram_username

# ── Access control (optional, for stage/dev instances) ───────────────────────
# Restrict the instance to allowed users; everyone else can only /start and
# gets a redirect reply. Seeded additively on boot — the admin dashboard's
# Access Control panel is the source of truth afterwards.
# EXPENSE_ALLOWED_USERS_ONLY=true
# EXPENSE_ALLOWED_USERS=alice,@bob,123456789

# ── AI Classification (optional) ─────────────────────────────────────────────
# Set one or both to enable AI-powered subcategory classification.
# With both set, requests rotate across providers (Gemini first) and fail over on rate-limit.
# GEMINI_API_KEY=your_gemini_api_key
# OPENROUTER_API_KEY=your_openrouter_api_key
# Requests served by one provider before rotating to the next (default 15).
# AI_STICKY_WINDOW=15
# Override the model per provider (defaults shown).
# GEMINI_MODEL=gemini-3.1-flash-lite
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# ── PostgreSQL overrides (optional) ──────────────────────────────────────────
# These override values from configs/.khorcha-pati.yaml when set.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=expense
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_SSL_MODE=disable

# ── Health ping (optional) ───────────────────────────────────────────────────
# If set, the bot pings {BASE_URL}/healthz every 20 min as a keep-alive.
# BASE_URL=https://your-domain.com

# ── Web Dashboard (optional) ─────────────────────────────────────────────────
# WEB_ENABLED=true
# WEB_JWT_SECRET=your-jwt-secret-min-32-chars
# WEB_REFRESH_SECRET=your-refresh-secret-min-32-chars
# WEB_BOT_USERNAME=your_bot_username
# WEB_PORT=:8081
#
# Production example (nginx proxy: khorcha-pati-api.mrahman.xyz -> node:8081):
# WEB_CORS_ORIGIN=https://khorcha-pati.mrahman.xyz
# WEB_BASE_URL=https://khorcha-pati-api.mrahman.xyz

# ── Google Drive backup (optional) ───────────────────────────────────────────
# Path to service account JSON for SQLite backup to Google Drive.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
