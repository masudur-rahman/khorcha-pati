# ══════════════════════════════════════════════════════════════════════════════
# Expense Tracker Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit a filled-in .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Telegram (required) ──────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── AI Classification (optional) ─────────────────────────────────────────────
# Set one or both to enable AI-powered subcategory classification.
# Gemini is tried first; OpenRouter is used as fallback.
# GEMINI_API_KEY=your_gemini_api_key
# OPENROUTER_API_KEY=your_openrouter_api_key

# ── PostgreSQL overrides (optional) ──────────────────────────────────────────
# These override values from configs/.expense-tracker.yaml when set.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=expense
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_SSL_MODE=disable

# ── Health ping (optional) ───────────────────────────────────────────────────
# If set, the bot pings {BASE_URL}/healthz every 20 min as a keep-alive.
# BASE_URL=https://your-domain.com

# ── Web Dashboard (optional) ─────────────────────────────────────────────────
# WEB_ENABLED=true
# WEB_JWT_SECRET=your-jwt-secret-min-32-chars
# WEB_REFRESH_SECRET=your-refresh-secret-min-32-chars
# WEB_BOT_USERNAME=your_bot_username
# WEB_PORT=:8081
#
# Production example (nginx proxy: expense-api.mrahman.xyz -> node:8081):
# WEB_CORS_ORIGIN=https://expense.mrahman.xyz
# WEB_BASE_URL=https://expense-api.mrahman.xyz

# ── Google Drive backup (optional) ───────────────────────────────────────────
# Path to service account JSON for SQLite backup to Google Drive.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
