<!DOCTYPE html>
<html><head><meta charset="UTF-8"><script>
function subst() {
  var vars = {};
  var x = window.location.search.substring(1).split('&');
  for (var i in x) { var z = x[i].split('=', 2); vars[z[0]] = decodeURIComponent(z[1]); }
  var els = document.getElementsByClassName('page-counter');
  for (var j = 0; j < els.length; ++j) { els[j].textContent = vars.page + ' / ' + vars.topage; }
}
</script>
<style>
  body { margin: 0; padding: 0 10mm; font-family: 'DM Sans', Arial, sans-serif; font-size: 9px; color: #6B778C; }
  .row { display: flex; justify-content: space-between; align-items: center; padding-top: 4px; border-top: 1px solid #DFE1E6; }
</style></head>
<body onload="subst()">
<div class="row">
  <span>Expense Tracker Bot</span>
  <span class="page-counter"></span>
</div>
</body></html>
