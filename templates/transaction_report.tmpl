<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        * {
            font-family: "Lohit Bengali", "DejaVu Sans", "Arial", sans-serif;
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
        }

        .content-table {
            border-collapse: collapse;
            margin: 15px 0;
            font-size: 0.9em;
            width: 100%;
            table-layout: fixed;
            border-radius: 5px 5px 0 0;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.15);
            page-break-inside: avoid !important;
        }

        .content-table thead tr {
            background-color: #009879;
            color: #ffffff;
            text-align: left;
            font-weight: bold;
        }

        .content-table th,
        .content-table td {
            padding: 12px 15px;
            word-break: break-word;
            vertical-align: top;
        }

        .content-table th {
            white-space: nowrap;
        }

        .content-table td {
            font-size: 0.85em;
        }
        
        .content-table .date,
        .content-table .type,
        .content-table .category {
            white-space: nowrap;
        }

        .content-table .amount {
            white-space: nowrap;
        }

        .content-table tbody tr {
            border-bottom: 1px solid #dddddd;
        }

        .content-table tbody tr:nth-of-type(even) {
            background-color: #f8f8f8;
        }

        .content-table tbody tr:last-of-type {
            border-bottom: 3px solid #009879;
        }
        .summary-section {
            margin-top: 30px;
        }

        /* Summary table adjustments */
        .summary-table {
            width: 50%;
            margin: 15px 0;
        }

        h2 {
            font-size: 1.4em;
            margin: 15px 0 10px;
            color: #333;
        }

        /* Column widths */
        .col-date { width: 10%; }
        .col-type { width: 8%; }
        .col-amount { width: 11%; }
        .col-source { width: 11.5%; }
        .col-dest { width: 11.5%; }
        .col-person { width: 10%; }
        .col-category { width: 12%; }
        .col-subcategory { width: 12%; }
        .col-remarks { width: 14%; }
    </style>
</head>

<body>
    <h2>Transaction History</h2>
    <table class="content-table transaction-history">
        <colgroup>
            <col class="col-date">
            <col class="col-type">
            <col class="col-amount">
            <col class="col-source">
            <col class="col-dest">
            <col class="col-person">
            <col class="col-category">
            <col class="col-subcategory">
            <col class="col-remarks">
        </colgroup>
        <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th style="text-align: right">Amount</th>
            <th>Source A/C</th>
            <th>Dest A/C</th>
            <th>Person</th>
            <th>Category</th>
            <th>Subcategory</th>
            <th>Remarks</th>
        </tr>
        </thead>
        <tbody>
        {{ range .Transactions }}
        <tr>
            <td class="date">{{ .Date.Format "Jan 02, '06" }}</td>
            <td class="type">{{ .Type }}</td>
            <td style="text-align: right" class="amount">৳{{ .Amount | formatBDT }}</td>
            <td>{{ .Source }}</td>
            <td>{{ .Destination }}</td>
            <td>{{ .Person }}</td>
            <td class="category">{{ .Category }}</td>
            <td>{{ .Subcategory }}</td>
            <td>{{ .Remarks }}</td>
        </tr>
        {{ end }}
        </tbody>
    </table>

    <div class="summary-section">
        <div style="page-break-inside: avoid !important;">
            <h2>Transaction Summary</h2>

            <table class="content-table summary-table">
                <colgroup>
                    <col style="width: 60%">
                    <col style="width: 40%">
                </colgroup>
                <thead>
                <tr>
                    <th>Transaction Type</th>
                    <th style="text-align: right">Amount</th>
                </tr>
                </thead>
                <tbody>
                {{ range $type := .Summary.Type }}
                <tr>
                    <td>{{ $type.Name }}</td>
                    <td style="text-align: right" class="amount">৳{{ $type.Amount | formatBDT }}</td>
                </tr>
                {{ end }}
                </tbody>
            </table>
        </div>

        <table class="content-table summary-table">
            <colgroup>
                <col style="width: 60%">
                <col style="width: 40%">
            </colgroup>
            <thead>
            <tr>
                <th>Transaction Category</th>
                <th style="text-align: right">Amount</th>
            </tr>
            </thead>
            <tbody>
            {{ range $category := .Summary.Category }}
            <tr>
                <td>{{ $category.Name }}</td>
                <td style="text-align: right" class="amount">৳{{ $category.Amount | formatBDT }}</td>
            </tr>
            {{ end }}
            </tbody>
        </table>

        <table class="content-table summary-table">
            <colgroup>
                <col style="width: 60%">
                <col style="width: 40%">
            </colgroup>
            <thead>
            <tr>
                <th>Transaction Subcategory</th>
                <th style="text-align: right">Amount</th>
            </tr>
            </thead>
            <tbody>
            {{ range $subcategory := .Summary.Subcategory }}
            <tr>
                <td>{{ $subcategory.Name }}</td>
                <td style="text-align: right" class="amount">৳{{ $subcategory.Amount | formatBDT }}</td>
            </tr>
            {{ end }}
            </tbody>
        </table>
    </div>
</body>
</html>
