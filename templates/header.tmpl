<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
{{ fontFaceCSS }}
<style>
  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; box-sizing: border-box; }
  html, body { margin: 0; padding: 0; width: 100%; }
  body { font-family: 'DM Sans', 'Lohit Bengali', 'DejaVu Sans', Arial, sans-serif; color: #172B4D; background: white; }
  .stmt-header { text-align: center; padding: 14mm 0 4mm; border-bottom: 3px solid #0052CC; }
  .stmt-header h1 { font-size: 26px; font-weight: 800; color: #0052CC; margin: 0 0 12px; font-family: 'Space Grotesk', 'DM Sans', Arial, sans-serif; }
  .stmt-header .name { font-size: 13px; color: #505F79; margin: 0 0 6px; font-weight: 600; }
  .stmt-header .range { font-size: 11px; color: #6B778C; margin: 0; }
</style>
</head>
<body>
  <div class="stmt-header">
    <h1>Khorcha-Pati Statement</h1>
    <p class="name">{{ .Name }}</p>
    <p class="range">{{ formatDateRange .StartDate .EndDate }}</p>
  </div>
</body>
</html>
